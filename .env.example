# =====================================================================
#  新学习助手 · 配置模板
# ---------------------------------------------------------------------
#  使用方式：
#  1. 把本文件复制为 .env（首次运行 run.bat 会自动复制）
#  2. 把下面的"请填写"替换成你的真实值
#  3. 重新运行 run.bat
#
#  注意：
#  - .env 文件已在 .gitignore 中，不会被提交到 GitHub，是安全的
#  - 不要直接修改 .env.example 后提交，那样会泄露 Key
# =====================================================================

# -------------- DeepSeek API（必填）--------------
# 在 https://platform.deepseek.com 申请，长度通常 32 位字母数字
DEEPSEEK_API_KEY=请填写你的DeepSeek_API_Key

# 模型接口地址，一般不需要改
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型名：deepseek-v4-flash（便宜快速，推荐课堂）/ deepseek-v4-pro（更强但贵）
DEEPSEEK_MODEL=deepseek-v4-flash

# Thinking 模式：disabled（关闭，更快、便宜）/ enabled（开启推理，慢、贵）
# 中学课堂体验推荐 disabled
DEEPSEEK_THINKING=disabled

# 仅在 DEEPSEEK_THINKING=enabled 时生效：high / max
DEEPSEEK_REASONING_EFFORT=high

# -------------- 教师监控看板（强烈建议设置）--------------
# 用于访问 /admin?token=xxx 监控面板
# 强烈建议使用 16 位以上随机字符串，例如：T7kQ9mN2vXp4Lb8r
# 留空 = 关闭看板
TEACHER_TOKEN=请填写一个足够长的随机字符串

# -------------- 并发与超时 --------------
# 同一时刻最多向模型发起多少个请求
# DeepSeek 个人/免费账户：建议 5~8；付费账户：可以调到 15~30
MODEL_CONCURRENCY=8

# 当并发已满，新请求最多排队多少秒
QUEUE_WAIT_SECONDS=4.0

# 单个模型请求的最长等待时间（秒）
REQUEST_TIMEOUT_SECONDS=45

# -------------- 输入输出限制 --------------
# 模型输出 token 上限（中文 1 token ≈ 1 字）
MAX_OUTPUT_TOKENS=600

# 学生单次输入的字符上限
MAX_INPUT_CHARS=500

# 携带几轮历史对话给模型
MAX_HISTORY_TURNS=3

# 单条历史消息保留多少字符
MAX_HISTORY_CHARS_PER_MESSAGE=300

# -------------- 短期限流（防连点）--------------
# RATE_LIMIT_WINDOW 秒内最多 RATE_LIMIT_COUNT 次
RATE_LIMIT_WINDOW=5
RATE_LIMIT_COUNT=2

# -------------- 课堂节奏提醒（防沉迷）--------------
# ANTI_ADDICTION_WINDOW 秒内提问超过 ANTI_ADDICTION_COUNT 次
# 就触发 ANTI_ADDICTION_COOLDOWN 秒冷却，提示学生"先整理笔记"
ANTI_ADDICTION_WINDOW=600
ANTI_ADDICTION_COUNT=5
ANTI_ADDICTION_COOLDOWN=300

# -------------- 缓存（多人展示场景建议关闭）--------------
# 关闭后每个问题都走模型，结果更新鲜，但更费 token
# 开启则相同问题在 CACHE_TTL_SECONDS 秒内共享一份答案
ENABLE_SHARED_CACHE=false
CACHE_SIZE=500
CACHE_TTL_SECONDS=1800

# -------------- 教师监控看板细节 --------------
# 看板上累计展示最近多少条事件
ADMIN_EVENT_CAPACITY=200

# 趋势聚合窗口（秒）：300 = 最近 5 分钟内重复 ≥2 次的问题会进入趋势区
ADMIN_TREND_WINDOW=300

# -------------- 反向代理 --------------
# 如果前面有 nginx 等反向代理传 X-Forwarded-For，设为 true
# 普通教室直连模式保持 false
TRUST_PROXY=false

# -------------- 提示词版本（一般不动）--------------
PROMPT_VERSION=learning-assistant-unified-v8-clean
